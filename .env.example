# VulnExus — Environment Variables
# Copy this file to .env and fill in your values.

# Base URL for the backend API (used when mock API is disabled)
VITE_API_BASE_URL=http://localhost:3001

# Application title shown in the browser tab
VITE_APP_TITLE=VulnExus

# Set to "true" to use the mock API layer instead of a real backend
VITE_ENABLE_MOCK_API=true

# Demo credentials (for development only — remove in production)
# VITE_DEMO_EMAIL=demo@vulnexus.io
# VITE_DEMO_PASSWORD=demo123
